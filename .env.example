# DBarf Configuration
# Copy this file to .env and fill in your settings

# ============================================
# Model Selection
# ============================================
# Options: 'gguf' (local GGUF model) or 'hf_api' (Hugging Face Inference API)
DBARF_MODEL_MODE=hf_api

# ============================================
# GGUF Model Settings (used when DBARF_MODEL_MODE=gguf)
# ============================================
# Model filename (must be in models/ directory)
GGUF_MODEL_NAME=qwen2.5-coder-3b-instruct-q4_k_m.gguf
GGUF_N_CTX=8192
GGUF_N_THREADS=8

# ============================================
# Hugging Face API Settings (used when DBARF_MODEL_MODE=hf_api)
# ============================================
# Get your token from: https://huggingface.co/settings/tokens
# You can set this OR add api_key to config.json
HF_API_TOKEN=your_huggingface_token_here

# Model ID on HuggingFace
# Recommended models for SQL generation:
#   - Qwen/Qwen2.5-Coder-32B-Instruct (best for SQL, requires Pro account)
#   - Qwen/Qwen2.5-Coder-7B-Instruct (good free alternative)
#   - defog/sqlcoder-7b-2 (specialized SQL model)
HF_MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct

# Maximum tokens to generate
HF_MAX_NEW_TOKENS=1024

# ============================================
# Debug Settings
# ============================================
# Print schema sent to LLM in console
DEBUG_PRINT_SCHEMA=true

# Log failed queries to error_queries.jsonl
DEBUG_LOG_QUERIES=true
